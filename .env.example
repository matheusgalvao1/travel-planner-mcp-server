# SerpApi powers both tools (Google Flights + Google Hotels).
# Get a key at https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your_serpapi_key

# Optional: override the SerpApi base endpoint.
SERPAPI_BASE_URL=https://serpapi.com/search.json

# Defaults applied when the caller omits them.
DEFAULT_CURRENCY=BRL
DEFAULT_MARKET=BR
DEFAULT_LOCALE=pt-BR

# Network timeout for supplier calls (ms).
REQUEST_TIMEOUT_MS=15000

# Set to 1 to run without real credentials (returns realistic mock data).
TRAVEL_MCP_MOCK=0
